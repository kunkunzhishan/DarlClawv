# Upstream endpoint and credentials
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...
# CODEX_API_KEY=sk-...  # Preferred by Codex CLI; if unset, runtime falls back to OPENAI_API_KEY
# OPENAI_MODEL=gpt-5-codex

# Codex executable/runtime overrides
# MYDARL_CODEX_COMMAND=codex
# MYDARL_CODEX_HOME=.mydarl-codex-home

# Memory vector/embedding (env overrides)
# MYDARL_MEMORY_EMBEDDING_PROVIDER=deterministic
# MYDARL_MEMORY_EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# MYDARL_MEMORY_EMBEDDING_MODEL=embedding-3
# MYDARL_MEMORY_EMBEDDING_API_KEY_ENV=EMBEDDING_API_KEY
# MYDARL_MEMORY_EMBEDDING_TIMEOUT_MS=20000
# MYDARL_MEMORY_EMBEDDING_FALLBACK=true
# MYDARL_MEMORY_SPLITTER_ENABLED=true
# MYDARL_MEMORY_SPLITTER_MAX_CHARS=400
# MYDARL_MEMORY_SPLITTER_OVERLAP_CHARS=60
# MYDARL_MEMORY_SPLITTER_MIN_CHUNK_CHARS=20
